{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 04 — Neural Network Training (DenseNet-121)\n",
    "\n",
    "Trains a DenseNet-121 model following the **CheXNet** approach  \n",
    "(Rajpurkar et al., 2017 — first model to exceed radiologist performance on pneumonia detection).\n",
    "\n",
    "### Training Strategy:\n",
    "- **Stage 1** (epochs 1-3): Freeze DenseNet backbone, train classifier head only\n",
    "- **Stage 2** (epochs 4+): Unfreeze entire network, fine-tune with lower LR\n",
    "- **Loss**: CrossEntropy with inverse-frequency class weights\n",
    "- **Sampler**: WeightedRandomSampler for balanced batches\n",
    "- **Tracking**: Full MLflow experiment logging\n",
    "- **Checkpointing**: Best model saved by Val AUC-ROC"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import torch\n",
    "import mlflow\n",
    "\n",
    "from src.data import build_dataloaders\n",
    "from src.models import build_model\n",
    "from src.training import Trainer\n",
    "from src.utils.metrics import print_clinical_report\n",
    "from src.utils.visualization import plot_confusion_matrix, plot_roc_curve\n",
    "\n",
    "mlflow.set_tracking_uri('../mlruns')\n",
    "\n",
    "DEVICE = 'cuda' if torch.cuda.is_available() else ('mps' if torch.backends.mps.is_available() else 'cpu')\n",
    "print(f'Device: {DEVICE}')\n",
    "\n",
    "DATA_ROOT  = '../chest_xray'\n",
    "BATCH_SIZE = 32\n",
    "EPOCHS     = 30\n",
    "LR         = 1e-4"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Build Dataloaders"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "train_loader, val_loader, test_loader = build_dataloaders(\n",
    "    DATA_ROOT,\n",
    "    image_size=224,\n",
    "    batch_size=BATCH_SIZE,\n",
    "    num_workers=4,\n",
    "    use_weighted_sampler=True,\n",
    ")\n",
    "\n",
    "# Class weights for loss function\n",
    "class_weights = train_loader.dataset.get_class_weights()\n",
    "print(f'Train size: {len(train_loader.dataset)}')\n",
    "print(f'Val size:   {len(val_loader.dataset)}')\n",
    "print(f'Test size:  {len(test_loader.dataset)}')\n",
    "print(f'Class weights: NORMAL={class_weights[0]:.4f}, PNEUMONIA={class_weights[1]:.4f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Initialize Model & Trainer"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "model = build_model(\n",
    "    backbone='densenet121',\n",
    "    num_classes=2,\n",
    "    dropout=0.5,\n",
    "    pretrained=True,\n",
    "    device=DEVICE,\n",
    ")\n",
    "\n",
    "total_params = sum(p.numel() for p in model.parameters())\n",
    "trainable_params = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "print(f'Total parameters:     {total_params:,}')\n",
    "print(f'Trainable parameters: {trainable_params:,}')\n",
    "\n",
    "trainer = Trainer(\n",
    "    model=model,\n",
    "    train_loader=train_loader,\n",
    "    val_loader=val_loader,\n",
    "    device=DEVICE,\n",
    "    learning_rate=LR,\n",
    "    weight_decay=1e-5,\n",
    "    epochs=EPOCHS,\n",
    "    freeze_backbone_epochs=3,\n",
    "    class_weights=class_weights,\n",
    "    scheduler_type='cosine_annealing',\n",
    "    early_stopping_patience=7,\n",
    "    use_amp=(DEVICE == 'cuda'),\n",
    "    checkpoint_dir='../models_saved',\n",
    "    experiment_name='chest-xray-pneumonia',\n",
    "    run_name='densenet121_baseline',\n",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Train"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "best_metrics = trainer.train(\n",
    "    params_to_log={\n",
    "        'backbone': 'densenet121',\n",
    "        'image_size': 224,\n",
    "        'augmentation': 'full_medical_pipeline',\n",
    "        'class_weighting': 'inverse_frequency',\n",
    "        'sampler': 'weighted_random',\n",
    "    }\n",
    ")\n",
    "\n",
    "print_clinical_report(best_metrics, 'Best Validation Metrics')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Test Set Evaluation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "from src.utils.metrics import compute_clinical_metrics, find_optimal_threshold\n",
    "\n",
    "model.eval()\n",
    "all_preds, all_labels, all_probs = [], [], []\n",
    "\n",
    "with torch.no_grad():\n",
    "    for images, labels in test_loader:\n",
    "        images = images.to(DEVICE)\n",
    "        logits = model(images)\n",
    "        probs  = torch.softmax(logits, dim=1)[:, 1].cpu().numpy()\n",
    "        preds  = (probs >= 0.5).astype(int)\n",
    "        all_probs.extend(probs.tolist())\n",
    "        all_preds.extend(preds.tolist())\n",
    "        all_labels.extend(labels.numpy().tolist())\n",
    "\n",
    "y_true  = np.array(all_labels)\n",
    "y_pred  = np.array(all_preds)\n",
    "y_probs = np.array(all_probs)\n",
    "\n",
    "# Standard evaluation at threshold=0.5\n",
    "metrics_05 = compute_clinical_metrics(y_true, y_pred, y_probs)\n",
    "print_clinical_report(metrics_05, 'DenseNet-121 Test Results (threshold=0.50)')\n",
    "\n",
    "# Clinical threshold: maximize sensitivity (minimize missed pneumonia)\n",
    "best_thresh, metrics_sens = find_optimal_threshold(y_true, y_probs, 'sensitivity', target_sensitivity=0.95)\n",
    "print_clinical_report(metrics_sens, f'DenseNet-121 Test Results (threshold={best_thresh:.3f}, sensitivity≥0.95)')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plot_confusion_matrix(\n",
    "    y_true, y_pred,\n",
    "    title='DenseNet-121 Test Set Confusion Matrix',\n",
    "    save_path='../reports/nn_confusion_matrix.png',\n",
    ")\n",
    "\n",
    "plot_roc_curve(\n",
    "    y_true,\n",
    "    {'DenseNet-121': y_probs},\n",
    "    title='DenseNet-121 ROC Curve — Test Set',\n",
    "    save_path='../reports/nn_roc_curve.png',\n",
    ")"
   ]
  }
 ],
