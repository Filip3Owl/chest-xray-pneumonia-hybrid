{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 05 — Hybrid Neuro-Symbolic System\n",
    "\n",
    "Combines the DenseNet-121 neural network with the rule-based expert system  \n",
    "using three fusion strategies:\n",
    "\n",
    "1. **Weighted Average** — fixed linear combination of NN prob + expert score\n",
    "2. **Dempster-Shafer** — evidence-theoretic fusion with uncertainty quantification\n",
    "3. **Meta-Learner** — logistic regression trained on [NN probs + expert features]\n",
    "\n",
    "The meta-learner is the most powerful strategy as it learns the optimal  \n",
    "combination weight from data, including which expert features are most useful."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import random\n",
    "from pathlib import Path\n",
    "from tqdm.notebook import tqdm\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import torch\n",
    "import cv2\n",
    "import mlflow\n",
    "\n",
    "from src.models import build_model, ChestExpertSystem, HybridNeuroSymbolicSystem\n",
    "from src.data import ChestXRayDataset, build_dataloaders\n",
    "from src.data.dataset import get_transforms\n",
    "from src.utils.metrics import compute_clinical_metrics, print_clinical_report, find_optimal_threshold\n",
    "from src.utils.visualization import plot_confusion_matrix, plot_roc_curve\n",
    "\n",
    "mlflow.set_tracking_uri('../mlruns')\n",
    "DEVICE = 'cuda' if torch.cuda.is_available() else ('mps' if torch.backends.mps.is_available() else 'cpu')\n",
    "DATA_ROOT = '../chest_xray'\n",
    "print(f'Device: {DEVICE}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Trained Neural Network"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load the best model checkpoint saved during training\n",
    "model = build_model('densenet121', num_classes=2, pretrained=False, device=DEVICE)\n",
    "checkpoint = torch.load('../models_saved/best_model.pth', map_location=DEVICE)\n",
    "model.load_state_dict(checkpoint['model_state_dict'])\n",
    "model.eval()\n",
    "print(f'Model loaded from epoch {checkpoint[\"epoch\"]} | Val AUC: {checkpoint[\"val_metrics\"][\"auc_roc\"]:.4f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Build Hybrid System"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "expert = ChestExpertSystem()\n",
    "\n",
    "hybrid_systems = {\n",
    "    'weighted': HybridNeuroSymbolicSystem(\n",
    "        model, expert, combination_method='weighted',\n",
    "        nn_weight=0.65, expert_weight=0.35, device=DEVICE\n",
    "    ),\n",
    "    'dempster_shafer': HybridNeuroSymbolicSystem(\n",
    "        model, expert, combination_method='dempster_shafer', device=DEVICE\n",
    "    ),\n",
    "    'meta_learner': HybridNeuroSymbolicSystem(\n",
    "        model, expert, combination_method='meta_learner', device=DEVICE\n",
    "    ),\n",
    "}\n",
    "print('Hybrid systems initialized:', list(hybrid_systems.keys()))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Train Meta-Learner on Validation Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Collect test set data for meta-learner training\n",
    "# (in practice use a separate held-out calibration set)\n",
    "_, val_loader, _ = build_dataloaders(DATA_ROOT, batch_size=1, num_workers=0)\n",
    "\n",
    "val_ds = ChestXRayDataset(DATA_ROOT, 'val', 224, get_transforms('val', 224), return_path=True)\n",
    "\n",
    "tensors, raw_images, labels = [], [], []\n",
    "for tensor, label, path in tqdm(val_ds, desc='Loading val data'):\n",
    "    img = cv2.imread(path)\n",
    "    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n",
    "    tensors.append(tensor)\n",
    "    raw_images.append(img)\n",
    "    labels.append(label)\n",
    "\n",
    "print(f'Meta-learner training samples: {len(labels)}')\n",
    "print(f'  NORMAL: {labels.count(0)}, PNEUMONIA: {labels.count(1)}')\n",
    "\n",
    "# Train meta-learner\n",
    "ml_metrics = hybrid_systems['meta_learner'].train_meta_learner(\n",
    "    tensors, raw_images, labels, cv_folds=5\n",
    ")\n",
    "\n",
    "# Save meta-learner\n",
    "hybrid_systems['meta_learner'].save_meta_learner('../models_saved/meta_learner.pkl')\n",
    "print('Meta-learner saved')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Evaluate All Systems on Test Set"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def evaluate_hybrid_on_test(hybrid, system_name, max_samples=300):\n",
    "    \"\"\"Evaluate a hybrid system on the test set.\"\"\"\n",
    "    test_ds = ChestXRayDataset(DATA_ROOT, 'test', 224, get_transforms('test', 224), return_path=True)\n",
    "    \n",
    "    y_true, y_pred, y_probs = [], [], []\n",
    "    \n",
    "    for i, (tensor, label, path) in enumerate(tqdm(test_ds, desc=system_name)):\n",
    "        if i >= max_samples:\n",
    "            break\n",
    "        img = cv2.imread(path)\n",
    "        img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n",
    "        result = hybrid.predict(tensor, img)\n",
    "        y_true.append(label)\n",
    "        y_pred.append(result['prediction'])\n",
    "        y_probs.append(result['final_probability'])\n",
    "    \n",
    "    return np.array(y_true), np.array(y_pred), np.array(y_probs)\n",
    "\n",
    "results = {}\n",
    "for name, hybrid in hybrid_systems.items():\n",
    "    print(f'\\nEvaluating {name}...')\n",
    "    y_true, y_pred, y_probs = evaluate_hybrid_on_test(hybrid, name, max_samples=300)\n",
    "    metrics = compute_clinical_metrics(y_true, y_pred, y_probs)\n",
    "    results[name] = {'metrics': metrics, 'y_true': y_true, 'y_probs': y_probs}\n",
    "    print_clinical_report(metrics, f'{name.upper()} System')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Also get pure NN results for comparison\n",
    "_, _, test_loader = build_dataloaders(DATA_ROOT, batch_size=32, num_workers=0)\n",
    "nn_probs_all, nn_labels_all = [], []\n",
    "with torch.no_grad():\n",
    "    for imgs, labels in test_loader:\n",
    "        probs = torch.softmax(model(imgs.to(DEVICE)), dim=1)[:, 1].cpu().numpy()\n",
    "        nn_probs_all.extend(probs.tolist())\n",
    "        nn_labels_all.extend(labels.tolist())\n",
    "nn_metrics = compute_clinical_metrics(\n",
    "    np.array(nn_labels_all),\n",
    "    (np.array(nn_probs_all) >= 0.5).astype(int),\n",
    "    np.array(nn_probs_all)\n",
    ")\n",
    "results['neural_net_only'] = {'metrics': nn_metrics, 'y_true': np.array(nn_labels_all), 'y_probs': np.array(nn_probs_all)}\n",
    "\n",
    "# Comparison table\n",
    "compare_df = pd.DataFrame({\n",
    "    name: {\n",
    "        'AUC-ROC':     res['metrics']['auc_roc'],\n",
    "        'Sensitivity': res['metrics']['sensitivity'],\n",
    "        'Specificity': res['metrics']['specificity'],\n",
    "        'F1':          res['metrics']['f1_score'],\n",
    "        'Accuracy':    res['metrics']['accuracy'],\n",
    "    }\n",
    "    for name, res in results.items()\n",
    "}).T.round(4)\n",
    "\n",
    "print('\\n' + '='*65)\n",
    "print('COMPARISON: All Systems on Test Set')\n",
    "print('='*65)\n",
    "print(compare_df.to_string())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ROC comparison plot\n",
    "roc_probs = {name: res['y_probs'] for name, res in results.items()}\n",
    "y_true_ref = results['neural_net_only']['y_true']\n",
    "\n",
    "# Use full test set probs for NN; align sample counts for hybrid\n",
    "plot_roc_curve(\n",
    "    results['neural_net_only']['y_true'],\n",
    "    {'Neural Net Only': results['neural_net_only']['y_probs']},\n",
    "    title='ROC Curves — All Systems Compared',\n",
    "    save_path='../reports/hybrid_roc_comparison.png',\n",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Single Patient Prediction Demo"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from src.data.dataset import get_transforms\n",
    "\n",
    "random.seed(99)\n",
    "test_paths = {\n",
    "    'PNEUMONIA': random.choice(list((Path(DATA_ROOT) / 'test' / 'PNEUMONIA').glob('*.jpeg'))),\n",
    "    'NORMAL':    random.choice(list((Path(DATA_ROOT) / 'test' / 'NORMAL').glob('*.jpeg'))),\n",
    "}\n",
    "transform = get_transforms('test', 224)\n",
    "\n",
    "for true_label, path in test_paths.items():\n",
    "    img = cv2.imread(str(path))\n",
    "    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n",
    "    tensor = transform(image=img)['image']\n",
    "    \n",
    "    result = hybrid_systems['meta_learner'].predict(tensor, img)\n",
    "    \n",
    "    print(f'\\n{\"─\"*55}')\n",
    "    print(f'  Patient File:    {path.name}')\n",
    "    print(f'  True Diagnosis:  {true_label}')\n",
    "    print(f'  System Decision: {result[\"label\"]}')\n",
    "    print(f'  Confidence:      {result[\"confidence\"]:.3f}')\n",
    "    print(f'  NN Probability:  {result[\"nn_probability\"]:.3f}')\n",
    "    print(f'  Expert Score:    {result[\"expert_score\"]:.3f}')\n",
    "    print(f'  Findings:')\n",
    "    for finding in result['expert_findings']:\n",
    "        print(f'    • {finding}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Log hybrid system comparison to MLflow\n",
    "mlflow.set_experiment('chest-xray-pneumonia')\n",
    "with mlflow.start_run(run_name='hybrid_systems_comparison'):\n",
    "    for system_name, res in results.items():\n",
    "        for metric_name, value in res['metrics'].items():\n",
    "            if isinstance(value, (int, float)):\n",
    "                mlflow.log_metric(f'{system_name}_{metric_name}', value)\n",
    "    mlflow.log_artifact('../models_saved/meta_learner.pkl')\n",
    "    print('Hybrid comparison logged to MLflow')"
   ]
  }
 ],
